PORT=8080
PUBLIC_BASE_URL=https://payflow-smt-produccion-production.up.railway.app
PAYFLOW_BASE_URL=https://tu-dominio-payflow.vercel.app

# Debe ser exactamente el mismo valor de VOICE_RUNTIME_WEBHOOK_SECRET en Vercel.
VOICE_RUNTIME_WEBHOOK_SECRET=crea-un-secreto-largo-y-aleatorio
VOICE_SESSION_SECRET=crea-otro-secreto-largo-y-diferente

# Twilio continúa disponible como proveedor alternativo.
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURES=true
TWILIO_RELAY_LANGUAGE=es-US
TWILIO_RELAY_VOICE=
TWILIO_RELAY_TTS_PROVIDER=

# Telnyx: credenciales del Mission Control Portal y el asistente creado en AI Suite.
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_ASSISTANT_ID=assistant-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TELNYX_VALIDATE_SIGNATURES=true
# Déjalo vacío para usar la voz configurada en el asistente de Telnyx.
TELNYX_VOICE=

# OpenAI o cualquier API compatible con /v1/chat/completions (por ejemplo Groq).
# Se conserva para el proveedor Twilio/ConversationRelay.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
