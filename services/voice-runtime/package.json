{
  "name": "payflow-voice-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Runtime persistente multiempresa para Llamadas IA de PayFlow SMT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
