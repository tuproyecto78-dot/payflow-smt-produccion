# PayFlow SMT — Environment Variables Example
# Copy this file to .env.local (for development) or .env (for production)
# and fill in the real values. NEVER commit real credentials.

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=file:./prisma/dev.db

# ─── Session ────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string
# Canonical HTTPS origin, used to validate alternate provider callbacks.
APP_URL=

# ─── Admin identity (the account still authenticates with Supabase) ─
ADMIN_EMAIL=admin@payflow.smt

# ─── Supabase (required in production) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── ClickUp (server-only; gestión interna, no motor conversacional) ─
CLICKUP_API_TOKEN=
CLICKUP_TOKEN_REF=main_clickup_token

# ─── PayPhone (set PAYPHONE_ENV=production when ready) ──────────────
# Environment: disabled | sandbox | production
# Use "disabled" for preview/development without PayPhone
PAYPHONE_ENV=
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=
PAYPHONE_MODE=link
PAYPHONE_EXTERNAL_NOTIFICATION_ENABLED=
PAYPHONE_PREREGISTRATION_ENABLED=
# Required: configure PayPhone's notification URL as
# https://YOUR_DOMAIN/api/payphone/NotificacionPago?token=THIS_RANDOM_SECRET
PAYPHONE_WEBHOOK_SECRET=
# Enable only when PayPhone confirms Sale lookup support for your API Link contract.
PAYPHONE_WEBHOOK_VERIFY_WITH_API=false
# HMAC secret for provider-agnostic /api/payments/webhook integrations
PAYMENT_WEBHOOK_SECRET=

# ─── AI ──────────────────────────────────────────────────────────────
# Gemini is the active conversational engine for the internal simulator.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.6-flash
AI_PROVIDER=gemini
# Optional legacy key used only by other modules when explicitly selected.
OPENAI_API_KEY=
# Keep automatic delivery disabled until WhatsApp and approval controls are validated.
AI_AUTOMATIC_MODE_ENABLED=false

# ─── WhatsApp Business Cloud API ────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# WhatsApp Business Account ID (WABA), used to list approved templates.
WHATSAPP_WABA_ID=
WHATSAPP_CLIENT_ID=
WHATSAPP_PROVIDER=meta
# Meta Business Portfolio ID. Required only for super_admin WABA management.
META_BUSINESS_PORTFOLIO_ID=
# Set explicitly to an active Meta Graph API version, for example v22.0.
WHATSAPP_API_VERSION=

# ─── Llamadas IA (runtime externo Pipecat/Twilio/Fonoster/SIP) ─────
# Secreto aleatorio compartido para firmar cada POST del runtime con HMAC
# SHA-256 en el encabezado X-PayFlow-Signature. Nunca usar NEXT_PUBLIC_*.
VOICE_RUNTIME_WEBHOOK_SECRET=

# ─── Stripe (Checkout; Stripe Connect para cuentas por negocio) ────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Local development only. Never enable these in Production.
ALLOW_LOCAL_AUTH_FALLBACK=false
WHATSAPP_ALLOW_MOCK=false
WHATSAPP_ALLOW_UNSIGNED_WEBHOOKS=false
ALLOW_UNSIGNED_PAYMENT_WEBHOOKS=false
ALLOW_UNSIGNED_PAYPHONE_WEBHOOKS=false

# ─── Legal ──────────────────────────────────────────────────────────
PRIVACY_POLICY_VERSION=1.0
TERMS_VERSION=1.0

# ─── Preview Mode (optional) ────────────────────────────────────────
# Set to "true" to enable preview mode (treats PayPhone as disabled)
PAYFLOW_PREVIEW_MODE=
