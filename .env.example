# PayFlow SMT — Environment Variables Example
# Copy this file to .env.local (for development) or .env (for production)
# and fill in the real values. NEVER commit real credentials.

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=file:./prisma/dev.db

# ─── Session ────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string

# ─── Admin ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@payflow.smt
ADMIN_INITIAL_PASSWORD=change-this

# ─── Supabase (optional — for production database) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── ClickUp (server-only) ──────────────────────────────────────────
CLICKUP_API_TOKEN=
CLICKUP_TOKEN_REF=main_clickup_token

# ─── PayPhone (set PAYPHONE_ENV=production when ready) ──────────────
# Environment: disabled | sandbox | production
# Use "disabled" for preview/development without PayPhone
PAYPHONE_ENV=
PAYPHONE_PRODUCTION_TOKEN=
PAYPHONE_PRODUCTION_STORE_ID=
PAYPHONE_SANDBOX_TOKEN=
PAYPHONE_SANDBOX_STORE_ID=
PAYPHONE_API_LINK_ENABLED=
PAYPHONE_API_SALE_ENABLED=
PAYPHONE_USER_CHECK_ENABLED=
PAYPHONE_WEBHOOK_ENABLED=

# ─── AI ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
# AI_PROVIDER: Mock | Gemini | OpenAI
AI_PROVIDER=

# ─── WhatsApp Business Cloud API ────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=

# ─── Legal ──────────────────────────────────────────────────────────
PRIVACY_POLICY_VERSION=1.0
TERMS_VERSION=1.0

# ─── Preview Mode (optional) ────────────────────────────────────────
# Set to "true" to enable preview mode (treats PayPhone as disabled)
PAYFLOW_PREVIEW_MODE=
